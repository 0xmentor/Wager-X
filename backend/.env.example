NODE_ENV=development
PORT=4000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000
JWT_ACCESS_SECRET=replace-access-secret
JWT_REFRESH_SECRET=replace-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
ACCESS_COOKIE_NAME=wagerx_access
REFRESH_COOKIE_NAME=wagerx_refresh
AUTH_COOKIE_SAME_SITE=lax
# AUTH_COOKIE_DOMAIN=.yourdomain.com
DATABASE_URL=postgres://postgres:postgres@localhost:5432/solbet
USE_REDIS=false
# Optional when USE_REDIS=true:
# REDIS_URL=redis://localhost:6379
